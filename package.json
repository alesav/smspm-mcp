{
  "name": "smspm-mcp",
  "version": "1.0.0",
  "description": "MCP server for sending SMS via SMSPM — use Claude Desktop to send SMS messages",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "smspm-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sms",
    "smspm",
    "claude",
    "claude-desktop",
    "ai"
  ],
  "author": {
    "name": "Aleksandr",
    "url": "https://smspm.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GITHUB/smspm-mcp.git"
  },
  "homepage": "https://smspm.com",
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB/smspm-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0"
  }
